# Canonical SMSM management system.
# Use placeholders only here. Real secrets belong in deployment/private env vars.
SYSTEM_API_URL=https://your-system.example.com
SYSTEM_API_KEY=replace-with-shared-server-key
SYSTEM_APP_URL=https://your-system.example.com
SYSTEM_REVALIDATE_SECRET=replace-with-revalidation-secret
NEXT_PUBLIC_SITE_URL=https://smsm-store.example.com

# Local development only; never enable in production
SYSTEM_API_ALLOW_SEED_FALLBACK=false
